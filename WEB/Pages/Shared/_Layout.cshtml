<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shoes Store</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WEB.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-dark bg-opacity-10 d-flex flex-column min-vh-100">
    <div class="shadow bg-white">
        <div class="container py-1 d-flex">
            <div class="d-flex align-items-center gap-3 flex-grow-1">
                <h2 class="fw-semibold m-0">
                    Shoes Store
                </h2>

                <div class="vr"></div>

                <a class="text-decoration-none text-dark btn-light d-flex align-items-center fs-5">
                    <i class="bi bi-bag me-2 fs-4"></i>
                    Товары
                </a>

                <a class="text-decoration-none text-dark btn-light d-flex align-items-center fs-5">
                    <i class="bi bi-basket me-2 fs-4"></i>
                    Корзина
                </a>
            </div>
            <div class="d-flex flex-grow-0">
                <a class="btn btn-sm btn-primary d-flex align-items-center rounded-4 fs-5 px-3 py-0 fw">
                    <i class="bi bi-person me-1 fs-4"></i>
                    Профиль
                </a>
            </div>
        </div>
    </div>


    <div class="d-flex flex-grow-1">
        <div class="container bg-white shadow my-1 py-2">
            @RenderBody()
        </div>
    </div>

    <div class="bg-white">
        <div class="container text-muted">
            <i class="bi bi-c-circle"></i> 2026 - WEB - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
