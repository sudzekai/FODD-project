@page
@model WEB.Pages.LoginModel
@{
    ViewData["Title"] = "Вход";
}

<div class="min-vh-100 d-flex justify-content-center align-items-center">
    <div class="bg-white p-3 rounded-4 shadow-sm" style="width: 340px">

        <h2 class="fw-semibold text-center mb-1">Shoes Store</h2>
        <div class="text-center text-muted mb-3">Авторизация</div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger py-2 rounded-4 text-center">
                @TempData["Error"]
            </div>
        }

        <form method="post">
            <div class="mb-2">
                <label class="form-label">Логин</label>
                <input asp-for="AuthRequest.Login"
                       class="form-control rounded-4"
                       placeholder="Введите логин" />
            </div>

            <div class="mb-3">
                <label class="form-label">Пароль</label>
                <input asp-for="AuthRequest.Password"
                       type="password"
                       class="form-control rounded-4"
                       placeholder="Введите пароль" />
            </div>

            <button type="submit" class="btn btn-primary w-100 rounded-4 mb-2">
                Войти
            </button>

            <a href="/register" class="btn btn-outline-secondary w-100 rounded-4">
                Регистрация
            </a>
        </form>

    </div>
</div>