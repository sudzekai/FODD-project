@page "/admin/products/{id:int}"
@model WEB.Pages.Admin.Products.DetailsModel

@{
    ViewData["Title"] = "Товар";
}

<div class="bg-white p-2 shadow rounded-4 mb-2">
    <h2 class="fw-semibold m-0">
        Товар #@Model.Product.Id
    </h2>
</div>

<div class="bg-white p-3 shadow rounded-4">

    <!-- ================= MAIN UPDATE ================= -->
    <form method="post" asp-page-handler="Update" class="d-flex flex-column gap-3">

        <input type="hidden" asp-for="Product.Id" />

        <div class="row g-2">

            <div class="col-6">
                <label class="form-label">Название</label>
                <input asp-for="Product.Name" class="form-control rounded-4" />
            </div>

            <div class="col-6">
                <label class="form-label">Артикул</label>
                <input asp-for="Product.Article" class="form-control rounded-4" readonly />
            </div>

            <div class="col-4">
                <label class="form-label">Описание</label>
                <input asp-for="Product.Description" class="form-control rounded-4" />
            </div>

            <div class="col-4">
                <label class="form-label">Единица</label>
                <input asp-for="Product.Unit" class="form-control rounded-4" />
            </div>

            <div class="col-4">
                <label class="form-label">Количество</label>
                <input asp-for="Product.Quantity" class="form-control rounded-4" />
            </div>

            <div class="col-4">
                <label class="form-label">Размер</label>
                <input asp-for="Product.Size" class="form-control rounded-4" />
            </div>

            <div class="col-4">
                <label class="form-label">Цвет</label>
                <input asp-for="Product.Color" class="form-control rounded-4" />
            </div>
            
            <div class="col-4">
                <label class="form-label">Категория</label>
                <select asp-for="Product.CategoryId"
                        asp-items="Model.Categories"
                        class="form-select rounded-4">
                    <option value="0">Не выбрано</option>
                </select>
            </div>
        </div>

        <div class="d-flex gap-2">

            <button type="submit" class="btn btn-primary rounded-4">
                Сохранить
            </button>

            <a href="/admin/products"
               class="btn btn-outline-dark rounded-4">
                Назад
            </a>

        </div>

    </form>

    <hr class="my-2" />

    <!-- ================= PRICING ================= -->
    <form method="post" asp-page-handler="UpdatePricing" class="row g-2">

        <input type="hidden" asp-for="Product.Id" />

        <div class="col-6">
            <label class="form-label">Цена</label>
            <input asp-for="Product.Price" class="form-control rounded-4" />
        </div>

        <div class="col-6">
            <label class="form-label">Скидка</label>
            <input asp-for="Product.Discount" class="form-control rounded-4" />
        </div>

        <div class="col-12">
            <button class="btn btn-outline-primary rounded-4">
                Обновить цену
            </button>
        </div>

    </form>

    <hr class="my-2" />

    <!-- ================= RELATIONS ================= -->
    <form method="post" asp-page-handler="UpdateRelations" 
    class="row g-2">

        <input type="hidden" asp-for="Product.Id" />

        <div class="col-6">
            <label class="form-label">Производитель</label>
            <select asp-for="Product.ManufacturerId"
                    asp-items="Model.Manufacturers"
                    class="form-select rounded-4">
                <option value="0">Не выбрано</option>
            </select>
        </div>

        <div class="col-6">
            <label class="form-label">Поставщик</label>
            <select asp-for="Product.SupplierId"
                    asp-items="Model.Suppliers"
                    class="form-select rounded-4">
                <option value="0">Не выбрано</option>
            </select>
        </div>

        <div class="col-12">
                <button class="btn btn-outline-primary rounded-4 d-flex align-self-baseline">
                Обновить связи
            </button>
        </div>

    </form>

    <hr class="my-2" />

    <!-- ================= TAGS ================= -->
    <form method="post" asp-page-handler="Tags" class="d-flex flex-column gap-2">

        <div class="fw-semibold">Теги</div>

        <div class="text-muted">
            @if (Model.ProductTags.Any())
            {
                @string.Join(", ", Model.ProductTags)
            }
            else
            {
                <span>Нет тегов</span>
            }
        </div>

        <div class="d-flex gap-2">

            <select name="tagId"
                    asp-items="Model.TagsSelectList"
                    class="form-select rounded-4">
                <option value="">Выберите тег</option>
            </select>

            <button type="submit"
                    name="action"
                    value="add"
                    class="btn btn-outline-primary rounded-4">
                Добавить
            </button>

            <button type="submit"
                    name="action"
                    value="remove"
                    class="btn btn-outline-danger rounded-4">
                Удалить
            </button>

        </div>

    </form>

    <hr class="my-2" />

    <!-- ================= DELETE ================= -->
    <form method="post"
        asp-page-handler="Delete"
    class="d-flex justify-content-end">

        <input type="hidden" asp-for="Product.Id" />

        <button type="submit"
                class="btn btn-danger rounded-4">
                <i class="bi-trash"></i>
            Удалить 
        </button>

    </form>

</div>