@page "/admin/suppliers/{id:int}"
@model WEB.Pages.Admin.Suppliers.DetailsModel
@{
    ViewData["Title"] = "Поставщик";
}

<div class="bg-white p-2 shadow rounded-4 mb-2">
    <h2 class="fw-semibold m-0">
        Поставщик #@Model.Supplier.Id
    </h2>
</div>

<div class="bg-white p-3 shadow rounded-4">

    <form method="post" class="d-flex flex-column gap-2">

        <input type="hidden" asp-for="Supplier.Id" />

        <div>
            <label class="form-label">Название</label>
            <input asp-for="Supplier.Name"
                   class="form-control rounded-4" />
        </div>

        <div class="text-muted">
            ID: @Model.Supplier.Id
        </div>

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn btn-primary rounded-4">
                Сохранить
            </button>

            <div class="d-flex flex-grow-1">
                <a href="/admin/suppliers"
                   class="btn btn-outline-dark rounded-4">
                    Назад
                </a>
            </div>
            
            <button type="submit"
                name="isDeleting"
                value="true"
                    class="btn btn-danger rounded-4">
                    <i class="bi-trash"></i>
                Удалить
            </button>
        </div>
    </form>

</div>