@page
@model WEB.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Товары";
}

<form method="get">

    <div class="bg-white p-2 shadow rounded-4">
        <h2 class="fw-semibold">Товары</h2>

        <div class="mt-1">
            <div class="d-flex gap-1">
                <input type="text"
                       asp-for="GetRequest.SearchTerm"
                       class="form-control rounded-4"
                       placeholder="Поиск..." />

                <button type="submit" class="btn btn-primary rounded-4">
                    <i class="bi-search"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="mt-2 row g-2">

        <!-- FILTERS -->
        <div class="col-2">
            <div class="p-2 bg-white rounded-4 d-flex flex-column gap-2 shadow">

                <div class="fw-semibold fs-5">Сортировка</div>

                <select asp-for="GetRequest.OrderDirection" class="form-select rounded-4">
                    <option value="desc">Убывание</option>
                    <option value="asc">Возрастание</option>
                </select>

                <select asp-for="GetRequest.OrderBy" class="form-select rounded-4">
                    <option value="price">Цена</option>
                    <option value="discount">Скидка</option>
                </select>

                <hr />

                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           asp-for="IsOnlyDiscounted" />
                    <label class="form-check-label">Только со скидкой</label>
                </div>

                <label>Категория</label>
                <select asp-for="GetRequest.CategoryId"
                        asp-items="Model.Categories"
                        class="form-select rounded-4">
                    <option value="0">Все</option>
                </select>

                <label>Производитель</label>
                <select asp-for="GetRequest.ManufacturerId"
                        asp-items="Model.Manufacturers"
                        class="form-select rounded-4">
                    <option value="0">Все</option>
                </select>

                <label>Поставщик</label>
                <select asp-for="GetRequest.SupplierId"
                        asp-items="Model.Suppliers"
                        class="form-select rounded-4">
                    <option value="0">Все</option>
                </select>

                <label>Размер</label>
                <input asp-for="GetRequest.Size"
                       type="number"
                       class="form-control rounded-4" />

                <label>Цвет</label>
                <input asp-for="GetRequest.Color"
                       class="form-control rounded-4" />

                <button class="btn btn-primary rounded-4">Применить</button>

                <button class="btn btn-outline-dark rounded-4"
                        type="submit"
                        name="isReset"
                        value="true">
                    Сбросить
                </button>

            </div>
        </div>

        <!-- PRODUCTS -->
        <div class="col-10">
            <div class="p-2 bg-white shadow rounded-4">
                <div class="row g-2">

                    @foreach (var product in Model.Products)
                    {
                        var price = product.Discount > 0
                            ? product.Price * (100 - product.Discount) / 100m
                            : product.Price;

                        <div class="col-4">
                            <a class="text-decoration-none text-dark"
                               href="/products/@product.Id">

                                <div class="rounded-4 overflow-hidden d-flex justify-content-center"
                                     style="height: 325px;">
                                    <img src="~/Screenshot 2026-06-15 135809.png" />
                                </div>

                                <h4 class="fw-semibold mt-2">@product.Name</h4>

                                @if (product.Discount > 0)
                                {
                                    <div class="d-flex gap-2">
                                        <span class="text-success fw-semibold">
                                            @Math.Round(price, 2) руб.
                                        </span>
                                        <span class="text-muted text-decoration-line-through">
                                            @Math.Round(product.Price, 2) руб.
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <div class="fw-semibold">
                                        @Math.Round(product.Price, 2) руб.
                                    </div>
                                }

                            </a>
                        </div>
                    }

                </div>
            </div>
        </div>

    </div>

</form>