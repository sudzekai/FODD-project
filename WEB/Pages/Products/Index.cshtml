@page
@model WEB.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Товары";
}

<form method="get">

<div class="bg-white p-2 shadow rounded-4">
    <h2 class="fw-semibold">
        Товары
    </h2>

    <div class="mt-1">
        <div class="d-flex gap-1">
            <input type="text" asp-for="@Model.GetRequest.SearchTerm"
                    class="form-control rounded-4"
                    placeholder="Поиск..." />

            <button type="submit"
                    class="btn btn-primary btn-1x1 rounded-4">
                <i class="bi-search"></i>
            </button>
        </div>
    </div>
</div>


<div>
    <div class=" mt-1 row g-2">
        <div class="col-2 ">
            <div class="p-2 bg-white rounded-4 d-flex flex-column gap-1">
                <label class="text-nowrap me-1 fw-semibold fs-4">Сортировка:</label>

                <label class="text-nowrap me-1">Сортировать по:</label>
                <select asp-for="GetRequest.OrderDirection"
                            class="form-select rounded-4">
                    <option value="desc" selected>Убыванию</option>
                    <option value="asc">Возрастанию</option>
                </select>

                <select asp-for="GetRequest.OrderBy"
                            class="form-select rounded-4">
                    <option value="price" selected>Цены</option>
                    <option value="discount">Скидки</option>
                </select>

                <hr class="mt-2 mb-1" />

                <label class="text-nowrap me-1 fw-semibold fs-4">Фильтры:</label>

                <div class="form-control rounded-4 d-flex align-items-center gap-2">
                    <input class="form-check-input"
                            type="checkbox"
                            asp-for="IsOnlyDiscounted"
                            id="discountCheck" />

                    <label class="form-check-label mb-0"
                            for="discountCheck">
                        Только со скидкой
                    </label>
                </div>

                    <label>Категория:</label>
                    <select class="form-select rounded-4"
                        asp-items="Model.Categories"
                        asp-for="GetRequest.CategoryId">
                        <option value="" selected>Выберите категорию</option>
                </select>

                    <label>Производитель:</label>
                    <select class="form-select rounded-4"
                        asp-items="Model.Manufacturers"
                        asp-for="GetRequest.ManufacturerId">
                        <option value="" selected>Выберите производителя</option>
                </select>

                    <label>Поставщик:</label>
                    <select class="form-select rounded-4"
                        asp-items="Model.Suppliers"
                        asp-for="GetRequest.SupplierId">
                        <option value="" selected>Выберите поставщика</option>
                </select>

                <label>Размер:</label>
                <input class="form-control rounded-4" type="number" asp-for="GetRequest.Size"
                    placeholder="Размер..."/>

                    <label>Цвет:</label>
                    <input class="form-control rounded-4" type="text" asp-for="GetRequest.Color"
                    placeholder="Цвет..."/>

                <hr class="mt-2 mb-1" />
                
                <button type="submit"
                        class="btn btn-primary rounded-4">
                        Применить
                </button>
                <button type="submit"
                        name="isReset"
                        value="true"
                        class="btn btn-outline-dark rounded-4">
                        Сбросить
                </button>
            </div>
        </div>

        <div class="col-10 ">
            <div class="p-2 bg-white shadow rounded-4 flex-grow-1">
                <div class="row g-2">
                    @foreach (var product in Model.Products)
                    {
                        decimal price = product.Price;
                        if (product.Discount != 0)
                        {
                            price = product.Price * ((100 - product.Discount) / 100m);
                        }

                        <div class="col-4">
                            <a class="d-flex flex-column gap-1 text-decoration-none text-dark"
                               href="/products/@product.Id">

                                <div class="d-flex w-100 justify-content-center">
                                    <div class=" rounded-4 overflow-hidden d-flex justify-content-center"
                                         style="width: 100%; height: 325px">
                                        <img src="~/Screenshot 2026-06-15 135809.png"
                                             class="" />
                                    </div>
                                </div>

                                <h3 class="fw-semibold m-0">@product.Name</h3>

                                @if (product.Price != price)
                                {
                                    <div class="d-flex gap-1 align-items-baseline">
                                        <label class="fw-semibold fs-3 text-success">@Math.Round(price, 2) руб.</label>
                                        <label class="text-decoration-line-through text-muted">@Math.Round(product.Price, 2) руб.</label>
                                    </div>
                                }
                                else
                                {
                                    <label class="fw-semibold fs-3">@Math.Round(price, 2) руб.</label>
                                }
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

</div>
</form>